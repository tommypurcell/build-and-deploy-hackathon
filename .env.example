# Browser (safe to expose): from Vapi Dashboard → profile → Vapi API Keys → Public API Key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Assistant you created in Vapi (Dashboard → Assistants → copy ID)
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Optional but recommended for authenticated GitHub API access
GITHUB_TOKEN=

# Simplest option: paste the public repo URL you want to scan
GITHUB_REPO_URL=https://github.com/your-name/your-repo

# Alternative split config if you prefer separate fields
# GITHUB_REPO_OWNER=your-name
# GITHUB_REPO_NAME=your-repo

# Server-only: Google AI Studio key for structured notes (Gemini). Never expose to the client.
GEMINI_API_KEY=

# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
